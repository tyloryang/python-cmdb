# 应用
APP_NAME=DevOps Platform
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/devops_db

# Redis（Celery Broker）
REDIS_URL=redis://localhost:6379/0

# 邮件（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# 钉钉通知（可选）
DINGTALK_WEBHOOK=
